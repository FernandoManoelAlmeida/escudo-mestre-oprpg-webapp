{
  "name": "escudo-mestre-casa-webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null || true; rm -f .next/dev/lock 2>/dev/null; next dev --webpack",
    "postinstall": "patch-package",
    "build": "next build --webpack && node scripts/write-version.js",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "migrate:ameacas": "node scripts/migrate-ameacas.js",
    "migrate:regras": "node scripts/migrate-regras.js",
    "build:android:twa:init": "node scripts/init-twa.js",
    "build:android:twa": "cd android-twa && npx @bubblewrap/cli build",
    "build:capacitor": "cross-env BUILD_ANDROID_CAPACITOR=1 next build --webpack",
    "build:android:capacitor:init": "npm run build:capacitor && npx cap init \"Escudo Mestre\" \"com.escudo.mestre\" --web-dir=out && npx cap add android",
    "build:android:capacitor": "npm run build:capacitor && npx cap sync android && npx cap build android -- --release"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "next": "16.1.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.3.11"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^8.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.7",
    "jsdom": "^29.0.0",
    "patch-package": "^8.0.1",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
